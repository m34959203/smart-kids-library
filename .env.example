# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_kids_library
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smart_kids_library

# NextAuth
# Generate a strong value with:  openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_ME
NEXTAUTH_URL=http://localhost:3000

# Bootstrap admin (only used on first boot, when users table is empty)
# Use a strong password (>= 10 chars). Do NOT commit real secrets.
SEED_ADMIN_EMAIL=admin@library.kz
SEED_ADMIN_PASSWORD=REPLACE_ME_STRONG

# LLM Provider — диспетчер выбирает первого:
#   gemini  — только Gemini (по умолчанию, обратно совместимо)
#   groq    — Groq всегда первый (failover на Gemini при 429)
#   auto    — Groq если есть GROQ_API_KEY, иначе Gemini
LLM_PROVIDER=gemini

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_DAILY_TOKEN_LIMIT=1500000

# Groq (опционально — даёт бесплатный free-tier для chat-эндпоинтов).
# Пропуск ключа отключает диспетчер; всё пойдёт в Gemini.
# Модели можно переопределить через GROQ_MODEL_TEXT / GROQ_MODEL_JSON.
GROQ_API_KEY=
GROQ_MODEL_TEXT=llama-3.3-70b-versatile
GROQ_MODEL_JSON=openai/gpt-oss-120b

# ElevenLabs (for Kazakh TTS)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=your-voice-id

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHANNEL_ID=@your_channel

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_ACCOUNT_ID=your-instagram-account-id

# Cron secret for scheduled autopost worker (/api/social/tick)
# Generate with:  openssl rand -hex 24
CRON_SECRET=REPLACE_ME

# App settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=ru

# AI kill-switch + USD-cap.
# AI_DISABLED=1 → getClient() throws AiDisabledError, caller fallback'ится на FAQ.
# Теперь src/lib/ai-quota.ts реально применяет USD-cap к каждому Gemini-вызову
# (assertUsdBudget читает SUM(cost_usd) из ai_generations за UTC-сутки и за период).
AI_DISABLED=0
AI_USD_CAP_DAILY=0.50
AI_USD_CAP_TOTAL=4.50
AI_USD_CAP_PERIOD_START=2026-04-30

# Per-user квоты поверх глобальных (защита от единичного абюзера).
AI_USER_RPD=40         # макс вызовов/день на авторизованного юзера
AI_USER_RPM=5          # макс вызовов/минуту на юзера (burst)
AI_USER_USD_DAILY=0.05 # макс $/день на юзера
AI_ANON_RPD=12         # макс вызовов/день на IP (анонимы)
AI_ANON_RPM=3          # макс вызовов/минуту на IP
